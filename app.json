{
  "expo": {
    "name": "LaminCollect",
    "slug": "lamincollect",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0B0E13"
